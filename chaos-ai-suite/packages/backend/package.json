{
  "name": "@chaos-ai-suite/backend",
  "private": true,
  "version": "0.1.0",
  "description": "Agent orchestration backend for My Chaos AI Suite",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@chaos-ai-suite/shared": "*",
    "@fastify/cors": "^10.0.1",
    "@fastify/websocket": "^11.0.1",
    "fastify": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
